{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.daedalus/mcp-smart-prox",
  "description": "An MCP server that provides a smart proxy to other mcp servers",
  "repository": {
    "url": "https://github.com/daedalus/mcp-smart-proxy",
    "source": "github"
  },
  "version": "0.1.0.1",
  "packages": [
    {
      "registryType": "pypi",
      "identifier": "mcp-smart-proxy",
      "version": "0,1.0.1",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "description": "Your API key for the service",
          "isRequired": true,
          "format": "string",
          "isSecret": true,
          "name": "YOUR_API_KEY"
        }
      ]
    }
  ]
}
